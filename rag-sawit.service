[Unit]
Description=RAG DeepSeek Sawit API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=muhdansyarovy
WorkingDirectory=/home/muhdansyarovy/app-dev/11. RAG DeepSeek Sawit
ExecStart=/home/muhdansyarovy/app-dev/11. RAG DeepSeek Sawit/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
